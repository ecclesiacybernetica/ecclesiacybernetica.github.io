  number = {11},
  publisher = {Routledge, Taylor \& Francis Group},
  location = {New York ; London},
  abstract = {The book draws attention to the traditions of systems theory in their historical development, especially as related to the humanities and social sciences, and shows how from these traditions various contemporary developments have ensued. The term ‘systems theory’ is used to characterize a set of disparate yet related approaches to fields as varied as information theory, cybernetics, biology, sociology, history, literature, and philosophy. What unites each of these traditions of systems theory is a shared focus on general features of systems and their fundamental importance for diverse areas of life. Yet there are considerable differences among these traditions, and each tradition has developed its own methodologies, journals, and forms of anaylsis. This book explores this terrain and provides an overview of and guide to the traditions of systems theory in their considerable variety. The book draws attention to the traditions of systems theory in their historical development, especially as related to the humanities and social sciences, and shows how from these traditions various contemporary developments have ensued. It provides a guide for strains of thought that are key to understanding 20th century intellectual life in many areas. Contents: 1. Systems Theory: A Secret History of the 20th Century by Darrell P. Arnold Part I: Early Developments and Their Continued Repercussions Introduction 2. The Persistence of Information Theory by Philipp Schweighauser 3. Cybernetics: Thinking Through the Technology by Ranulph Glanville 4. Expanding the Self-Referential Paradox: The Macy Conferences and the Second Wave of Cybernetic Thinking by John Bruni 5. The Hermeneutical System of General Systemology: Bertalanffian and Other Early Contributions to Its Foundations and Development by David Pouvreau 6. The Ethics of Epistemology: The Work of the Constructivist and Cybernetician Heinz von Foerster, From the Vienna Circle to the Cybernetic Circle by Bernhard Pörksen 7. Maturana and Varela: From Autopoiesis to Systems Applications by Bob Mugerauer 8. Eugene Odum and the Homeostatic Ecosystem: the Resilience of an Idea by Joel Hagen Part II: Systems Thinking in Sociology Introduction 9. Talcott Parsons: A Sociological Theory of Action Systems by Bettina Mahlert 10. Luhmann: Three Key Concepts, System, Meaning, Autopoiesis by Walter Reese-Schäfer 11. Systems Historicized: Wallerstein’s World-Systems Analysis by Walter L. Goldfrank Part III: Further Contemporary Developments Introduction 12. Systems Theories and Literary Studies by Andrew McMurry 13. Systems Heuristics and Digital Culture by Raphael Sassower and Nimrod Bar-Am 14. A Brief Outline of Evolutionary Cultural Ecology by Peter Finke 15. Prigogine: The Interplay of Cosmos, Complexity, and Culture by Dorothea Olkowski 16. Systems Theory and Practice in Organizational Change and Development by Debora Hammond 17. Systems, Tools, and Bateson’s Cybernetics: A Joint Metalogue by Nora Bateson and Phillip Guddemi},
  isbn = {978-0-415-84389-8},
  pagetotal = {373},
  file = {/Users/tw/Zotero-2025-02-13/storage/9BQJ68Z4/Arnold - 2014 - Traditions of systems theory major figures and co.pdf}
}

