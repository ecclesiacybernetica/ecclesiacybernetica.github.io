@article{mele2019freely,
  title = {The “{{Freely Adaptive System}}”. {{Application}} of This {{Cybernetic Model}} to an {{Organization Formed}} by {{Two Dynamic Human Systems}}},
  author = {Melé, Domènec and Chinchilla, M. Nuria and López-Jurado, Marta},
  date = {2019-02},
  journaltitle = {Philosophy of Management},
  shortjournal = {Philosophy of Management},
  volume = {18},
  number = {1},
  pages = {89--106},
  url = {https://link.springer.com/10.1007/s40926-018-0098-x},
  urldate = {2024-04-22},
  abstract = {Management cybernetics has been in development since the 1960s, although its implementation has been relatively modest. Two of the best-known proposals are Beer’s Viable System Model and Steinbruner’s Cybernetic Theory of Decision. Both are homeostatic systems, inspired by living organisms. Professor Juan A. Pérez López (1934–1996) argued that homeostatic systems are not fully appropriated for human beings, and proposed instead the BFreely Adaptive System\textasciicircum{} (FAS) model to explain the dynamics of an organization formed by two dynamic human systems. This model, although it is within the management cybernetic paradigm, and does not propose any anthropological philosophy, is consistent with several features of the Aristotelian anthropological tradition, including epistemology, practical reason, and virtues. The FAS model can help as a compass for decision making by considering three basic criteria—effectiveness, internal efficiency and consistency—when two persons—an active agent and a reactive agent—interact repeatedly. The model sheds light on the interdependence of ethics and efficiency in successive interactions.},
  langid = {english},
  keywords = {Wichtig!},
  file = {/Users/tw/Zotero-2025-02-13/storage/7FDAJBRR/Melé et al. - 2019 - The “Freely Adaptive System”. Application of this .pdf}
}

