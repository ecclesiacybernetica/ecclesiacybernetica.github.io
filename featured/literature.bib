  title = {Theory and {{Observation}} in {{Cultural Transmission}}},
  author = {Cavalli-Sforza, L. L. and Feldman, M. W. and Chen, K. H. and Dornbusch, S. M.},
  date = {1982-10},
  journaltitle = {Science},
  volume = {218},
  number = {4567},
  pages = {19--27},
  publisher = {American Association for the Advancement of Science},
  url = {https://www.science.org/doi/abs/10.1126/science.7123211},
  urldate = {2024-08-12},
  abstract = {Cultural phenomena may show considerable stability over time and space. Transmission mechanisms responsible for their maintenance are worthy of theoretical and empirical inquiry; they are complex and each possible pathway has different effects on evolutionary stability of traits, as can be shown theoretically. A survey designed to evaluate the importance of some components of cultural transmission on a variety of traits showed that religion and politics are mostly determined in the family, a mode of transmission which guarantees high evolutionary stability and maintenance of high variation between and within groups.}
