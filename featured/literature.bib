@incollection{klyme2012begriffe,
  title = {Begriffe},
  booktitle = {Luhmann-Handbuch: Leben — Werk — Wirkung},
  author = {Klymenko, Iryna and Süssenguth, Florian and Müller, Julian and Opitz, Sven and Saake, Irmhild and Seßler, Katharina and Mellmann, Katja and Nassehi, Armin and Mayr, Katharina and Farzin, Sina and Atzeni, Gina and Fuchs, Peter and Mainzer, Klaus and Kuchler, Barbara and Grizelj, Mario and Stempfhuber, Martin and Kirchmeier, Christian and Jahraus, Oliver and Göbel, Andreas and Kirchmeier, Christian and Kirchmeier, Christian and family=Groddeck, given=Victoria, prefix=von, useprefix=true and Siri, Jasmin and Werron, Tobias},
  editor = {Jahraus, Oliver and Nassehi, Armin and Grizelj, Mario and Saake, Irmhild and Kirchmeier, Christian and Müller, Julian},
  date = {2012},
  pages = {69--128},
  publisher = {J.B. Metzler},
  location = {Stuttgart},
  url = {https://doi.org/10.1007/978-3-476-05271-1_4},
  urldate = {2024-04-06},
  abstract = {Bereits in den frühen 1980er Jahren nimmt Niklas Luhmann Bezug auf wissenschaftliche Innovationen, die im Wesentlichen auf biologischen und neurophysiologischen Forschungen basieren, aber zu dieser Zeit noch keinen Eingang in die Soziologie gefunden hatten. Hierbei handelt es sich vor allem um zwei radikale Veränderungen traditioneller systemtheoretischer Ansichten über die Natur komplexer Einheiten. So werden Systeme primär nicht mehr als ein aus Teilen bestehendes Ganzes aufgefasst; vielmehr geht es nun um die Beschreibung von Differenzen zwischen System und Umwelt. Als Folge dieses Paradigmenwechsels rückt die Frage, ob und wie eine bestehende Einheit erhalten werden kann, zugunsten der wissenschaftlichen Beschreibung des Entstehens und der Reproduktion von Differenzen in den Hintergrund. Systeme werden nunmehr hinsichtlich ihrer selbstreferentiellen Konstitution untersucht, wobei Selbstreferenz hierbei nicht mehr im Sinne von Reflexion oder Reflexivität eines Subjekts, sondern als das operative Selbstverhältnis eines Systems definiert ist.},
  isbn = {978-3-476-05271-1},
  langid = {ngerman}
}

