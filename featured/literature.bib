@article{ziete2020elity,
  title = {Elity Kontra Masy. {{Egalitarystyczna}} Propaganda versus Elitarystyczna Praktyka Polityczna Naszych Czasów},
  author = {Ziętek-Wielomska, Magdalena},
  date = {2020},
  journaltitle = {Pro Fide Rege et Lege},
  pages = {230--245},
  abstract = {Ein interessanter Artikel über den Prozess in dem die instrumentelle Vernunft die Menschliche Wirklichkeit erobern habe. Die Grichen haben den Begriff der Natur entdeckt, sie forschten die Wahrheit, die Römer forschten das Gute. Angriff an die WAhrhait ist mit Deskartes begonnen, die Materie sei lediglich Rex extensa, habe kein Telos, kann von Vernunft unbegrenzt manipuliert werden. KAnt und Idealismus, wir erkennen die Wirklichkeit nicht, sondern unser Denken. Popkultur hat die Nachfolgen in den Filmen Matrix und Inception dargestellt.  Angriff auf Ethik und Gute ist mit Machiavelli begonnen. Luter hat gesagt, dass der Mensch zerstört ist und muss den Behörden gehorchen. Er hat die Unterscheidung zwischen Forum internum und externum eingeführt. Der Mensch ist weder frei noch vernünftig, und als Konsequenz ist die Behauptung, dass die Moral in der Öffentlichkeit nicht verwendet werden kann. Politki muss nicht moralisch sein.  Kalvin habe die Rolle der Arbeit über Politik gehoben, die Arbeit ist gut, die Politik ist böse. (--{$>$}M Walzer). Als Konsequenz die Antwort auf den Gewalt ist nur gößere Gewalt. Hobbes, Protestant, sagte die Individuen sind unfähig nach Wahrheit und Gute zu streben. Leviatan bewahrt die Ordnung durch die Angst. Angsti ist die Grundlage der Politik. Mit der instrumentellen Vernunft der Mensch berechnet was für ihn mehr profitabel ist. Der Mensch wurde zum Objekt der Politik, die technische Charatker erworben habe. Aufklärung habe das weiter gebracht, Sapere aude, bedeutet auch, dass es Menschen gibt die schon aufgeklärten sind und die Unmündigen. Die zweite Grupe muss von den ersten geführt werden. Hegel hat das weiter entickelt und sagte, dass nicht der Mensch sondern der Staat ist Person, der Mensch wird vernunftig durch die Paritzipation in der Vernnunft des Staates. Das führt zur große Bedeutung von Beamten. Die Links hat das für sich intermretirt (Marxismus und NaSo mit ihren Eliten) In der Verienigten Staaten diese Entwicklung ging in der Richtung des Technokaritsmus (--{$>$} F. Fischer, Technocracy)  Das Ergebnis ist Triuph der instrumentelle Vernunft, auf den Preis des Gute und Wahrheit. Der Staat als Inkarnation der Rationalität kann die Individuen opfern für die Besserer Zunkunft.  Man konnte denken, dass Nürnberger Prozess oder die Deklaration der Menschenrechte eine Rückgang zur Naturrecht deutete, aber man interpretirte Totalitarismus als Widerstand der Dummen Massen gegen die Modernisierung. (Arend, Casirrer?) und Menschenwürde wurde instrumentel benuntzt und definiert. Es gab keine koherente Antropologie. Späte Neuzeit. Die Philosoophie wurde zur Kritische Theorie. Wenn die Vernunft nicht von Wirklichkeit erkennen kann, dann alles was wir über wirklichkiet wissen, muss ein Ergebniss der Unaufgeklärheit sein als die Menschen unter Einfluss der Authoritäten waren. Horkheimer und Adorno haben richtig gesagt, dass der instrumentale Vernunft alles untergeordnet wurde, die Beziehungen zwischen den Menschen und Mensch und Natur.  Ähnlich hat Baumann gesagt: Holocaust ist ein Ergebniss von Modernismus mit instrumentellen Vernunft. Das Hauptproblem und Grund dafür war die Ablehnung der Realitische Philosophie.  Postmodernismus wollte dekonstruiren die Resten der realitischen Denken, negiren Ritualen und soziale Normen um authentisch zu werden. Negieren sollten wir die geerbte Vorstelungen über die WElt und uns selbst. (z.B. unterscheidung zwischen Mann und Frau). Das aber würde sehr schnell zum Chaos führen. Die Authorin erwähnt auch Barnays Propaganda. Die Mechanismen sagen den Menschen was sie lliebhaben wollen und so die technische Vernunft beherschte die ganze Wirklichkeit. Das wurde geschehen trotz kritische Theorie, trotz Postmodernismus, zum Trotz der Mode auf postwahrheit. Die Konzeption die zugrunde der Teokratischen gestaltung der Gesellschaft liegt, vorausetzt die Irrationalität des Menschens. Vernunftig sind die Eliten. Das Bedeutet aber dass die Trennung der Gesellschaft auf Freien Bürger und Sklaven von Aristoteles hat sich nicht geändert. Die realitsiche Philosophie wurde sagen dass die Bewusstsein ist sehr verfälscht.},
  issue = {1 (83)},
  file = {/Users/tw/Zotero-2025-02-13/storage/4HHMAHE6/Ziętek-Wielomska - 2020 - Elity kontra masy. Egalitarystyczna propaganda ver.pdf}
}

