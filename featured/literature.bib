@article{gebau2014CrossculturalVariations,
  title = {Cross-Cultural Variations in {{Big Five}} Relationships with Religiosity: {{A}} Sociocultural Motives Perspective.},
  shorttitle = {Cross-Cultural Variations in {{Big Five}} Relationships with Religiosity},
  author = {Gebauer, Jochen E. and Bleidorn, Wiebke and Gosling, Samuel D. and Rentfrow, Peter J. and Lamb, Michael E. and Potter, Jeff},
  date = {2014},
  journaltitle = {Journal of Personality and Social Psychology},
  volume = {107},
  number = {6},
  pages = {1064--1091},
  publisher = {American Psychological Association (APA)},
  url = {https://doi.apa.org/doi/10.1037/a0037683},
  urldate = {2025-07-08},
  abstract = {A socio-cultural motives perspective (SMP) on Big Five relationships is introduced. According to the SMP, Agreeableness and Conscientiousness elicit assimilation to sociocultural norms, Openness elicits contrast from these norms, and Extraversion and Neuroticism are independent of socio-cultural assimilation and contrast. Due to socio-cultural assimilation, then, relationships of Agreeableness and Conscientiousness with an outcome will wax (become more positive or less negative) with that outcome’s increasing socio-cultural normativeness. Due to socio-cultural contrast, relationships of Openness with an outcome will wane (become less positive or more negative) with that outcome’s increasing socio-cultural normativeness. We tested the SMP using religiosity as our outcome. Study 1 included four cross-sectional self-report datasets across 66 countries (N = 1,129,334), 50 US states (N = 1,057,342), 15 German federal states (N = 20,885), and 121 British urban areas (N = 386,315). Study 2 utilized informant-report data across 37 countries (N = 544,512). Study 3 used longitudinal data across 15 German federal states (N = 14,858). Results consistently supported the SMP. Relationships of Agreeableness and Conscientiousness with religiosity were more positive in religious socio-cultural contexts, compared to secular contexts. Relationships of Openness with religiosity were more negative in religious socio-cultural contexts, compared to secular contexts. At a more general level, the SMP offers theory-driven explanations for cross-cultural variations in Big Five relationships with their outcomes.},
  langid = {english},
  file = {/Users/tw/Zotero-2025-02-13/storage/T9RGRB3V/Gebauer et al. - 2014 - Cross-cultural variations in Big Five relationship.pdf}
}

