  urldate = {2024-04-22},
  abstract = {Purpose – The purpose of this paper is to explore ways in which cybernetics leads to distinctive ways of acting. Design/methodology/approach – Paralleling von Foerster’s argument that it makes more sense to speak of the cybernetics of epistemology than the epistemology of cybernetics, the author argues that cybernetics is not one form of practice amongst others but an account of what it is to practice, understood as where we relate how we act to how we understand so that each informs the other. The author explores the potential difference that adopting this understanding of practice makes in practice and shows its significance by establishing connections between the eponymous cybernetic example of steering and questions regarding teleology in ethics.},
