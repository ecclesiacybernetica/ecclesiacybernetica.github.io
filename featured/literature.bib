@book{gener1955next,
  title = {The {{Next Step}} in {{Management}} - {{An Appraisal}} of {{Cybernetics}}},
  author = {{General Electric Co}},
  date = {1955-01-01},
  edition = {Second Printing edition},
  publisher = {New York: General Electric Co.},
  abstract = {Origin and Scope of This Report This report presents the results of an exploration of "Cybernetics and Management" undertaken in the Management Consultation Services Division from March to November of 1952, by Melvin L. Hurni, Consultant in that Division. Briefly the assignment was to: Develop awareness among General Electric management of prospective heavy impacts on the management problems, facilities, processes and products of Industry as a result of the trend of Electronic developments. Review the degree to which such Electronic developments are already being translated rapidly into equipment, machines and systems which perform automatically many functions previously performed manually; and check the resultant impact on personnel, managerial and other. Especially analyze the extent to which Electronic machines, systems or controls may replace not only manual labor but, increasingly also white collar labor and even scientific personnel and thus eliminate labor not only from physical work but from control, statistical and other essentially mental types of effort; including prospective effects of the availability of feed back, or memory and selectivity, functions through "thinking machines." Summarize the present "state of the art" in the field and endeavor to indicate its major short and long range impacts on ► Products and services salable in the future ► Manufacturing facilities, processes, machines and automatic operating controls of the future ► Markets and marketing, at all stages of distribution from factory to end customers ► Accounting, statistics, controls and finance in the corporate (and other) enterprises of the future ► Human relations-employee, owner, vendor, governmental and public; and finally on ► Management as such; and on managers and the future nature of their work and capacities to plan, organize, measure and integrate the scope and work of both business and nonprofit (including governmental) enterprises of increasing size, diversity and complexity. "Translate" such analyses and summaries into book form readable by Group, Division, Department and Section Managers and technical specialists of equivalent ranks and status, so that they may have adequate awareness of such current and prospective factors and impacts on the future needs for statesmanship in Management to sense, develop, coordinate and steer the work of Management through the changes so imminently impinging. Contents: Foreword 1. What is Cybernetics? 2. Why the Urgency? 3. Problems Incident to Automation 4. Examples of Mechanization and Automation 5. Computers 6. The Nature of Operations Research 7. As Management What Should We Do About It? 8. The Future as a Salable Commodity 9. A Concluding Thought Appendices},
  langid = {english}
}

