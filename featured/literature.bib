@article{ibera1968homeokinesis,
  title = {Homeokinesis - {{The Organizing Principle}} of {{Complex Living Systems}}},
  author = {Iberall, A. S. and McCulloch, W. S.},
  date = {1968-09-01},
  journaltitle = {IFAC Proceedings Volumes},
  shortjournal = {IFAC Proceedings Volumes},
  series = {{{IFAC Conference}} on {{Technical}} and {{Biological Problems}} of {{Control}} - {{A Cybernetic View}}, {{Yerevan}}, {{Armenia}}, {{September}} 24-28, 1968},
  volume = {2},
  number = {4},
  pages = {39--50},
  url = {https://www.sciencedirect.com/science/article/pii/S1474667017688372},
  urldate = {2024-05-05},
  abstract = {A schema is outlined for a useful way to think about the complex biological organism, in particular man, in a cybernetic sense. It is based on physiological findings that the regulating and control functions in the system make use of actively chained processes, exhibiting oscillatory properties. The resulting homeostatic regulation, which was the key concept proposed by Bernard - Sechenov - Cannon for the living system, emerges from mediation of these oscillators, mainly by release from inhibition. Because of its dynamic character, the scheme is renamed homeokinesis. The preferred means of analysis for such systems is spectroscopy (biospectroscopy) of the chains. This paper extends the concept to the behavioral complex for man. In briefly outlined form, it attempts to touch on all the time or frequency domains in behavior, that is, of the many episodes in man. The discourse is intended to be neither axiomatic, nor journalistic. The first five topics describe the system by a hierarchical sequence of ideas, from essential instability in the system, to the emergent organizing levels in the system, to the temporal spectrum of behavior - from its ‘moment’ to its lifetime. The last topic touches on the consequences of such organization for a number of the major questions of interest to man.},
  file = {/Users/tw/Zotero-2025-02-13/storage/VYMCLJ7K/S1474667017688372.html}
}

