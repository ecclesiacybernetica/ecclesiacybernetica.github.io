@book{ahren2022Kirchenaustri2018,
  title = {Kirchenaustritte seit 2018: Wege und Anlässe; Ergebnisse einer bundesweiten Repräsentativbefragung},
  shorttitle = {Kirchenaustritte seit 2018},
  author = {Ahrens, Petra-Angela},
